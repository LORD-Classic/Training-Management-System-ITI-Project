@model Training_Management_System_ITI_Project.ViewModels.CourseViewModel
@{
    ViewData["Title"] = "Create New Course";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-book me-2"></i>Create New Course
        </h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Course Information</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label"></label>
                                <input asp-for="Name" class="form-control" placeholder="Enter course name" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Category" class="form-label"></label>
                                <select asp-for="Category" class="form-select" asp-items="ViewBag.Categories">
                                    <option value="">-- Select Category --</option>
                                </select>
                                <span asp-validation-for="Category" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="InstructorId" class="form-label"></label>
                                <select asp-for="InstructorId" class="form-select" asp-items="ViewBag.Instructors">
                                    <option value="">-- Select Instructor (Optional) --</option>
                                </select>
                                <span asp-validation-for="InstructorId" class="text-danger"></span>
                                <small class="form-text text-muted">You can assign an instructor later if needed.</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Create Course
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Course Guidelines</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-primary">
                            <i class="fas fa-info-circle me-2"></i>Course Name
                        </h6>
                        <p class="text-muted small">Must be unique across all courses. Use descriptive names that clearly identify the course content.</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-success">
                            <i class="fas fa-tag me-2"></i>Category
                        </h6>
                        <p class="text-muted small">Choose an appropriate category to help organize and find courses easily.</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-info">
                            <i class="fas fa-user-tie me-2"></i>Instructor
                        </h6>
                        <p class="text-muted small">Assign an instructor who will be responsible for delivering the course content and managing sessions.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
